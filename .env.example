# Database
POSTGRES_USER=personalife
POSTGRES_PASSWORD=personalife_secret
POSTGRES_DB=personalife

# Redis
REDIS_PASSWORD=redis_secret

# Auth
JWT_SECRET=change_this_in_production_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# App
MAX_UPLOAD_SIZE_MB=10

# Public URL (for OAuth redirects + iCal links)
APP_PUBLIC_URL=http://localhost:5173

# Telegram bot (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Google Calendar OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google/callback

# Frontend (Vite)
VITE_API_URL=http://localhost:4000
